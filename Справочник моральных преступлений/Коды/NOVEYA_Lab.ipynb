{"cells": [{"cell_type": "markdown", "metadata": {}, "source": ["# \ud83c\udf0d NOVEYA Lab \u2014 \u0418\u043d\u0442\u0435\u0440\u0430\u043a\u0442\u0438\u0432\u043d\u0430\u044f \u041c\u0435\u0442\u0430\u043f\u043b\u0430\u0442\u0444\u043e\u0440\u043c\u0430\n", "\u042d\u0442\u043e\u0442 Google Colab \u043f\u0440\u043e\u0435\u043a\u0442 \u043e\u0431\u044a\u0435\u0434\u0438\u043d\u044f\u0435\u0442 **\u0415\u0434\u0438\u043d\u0443\u044e \u041c\u0435\u0442\u043e\u0434\u043e\u043b\u043e\u0433\u0438\u044e \u041d\u041e\u0412\u0415\u042f** \u0438 \u0441\u043f\u0438\u0441\u043e\u043a \u043f\u0440\u043e\u0435\u043a\u0442\u043e\u0432, \u043f\u0440\u0438\u043c\u0435\u043d\u0438\u043c\u044b\u0445 \u0434\u043b\u044f \u0433\u0440\u0430\u043d\u0442\u043e\u0432, \u0446\u0438\u0444\u0440\u043e\u0432\u043e\u0433\u043e \u0443\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u044f \u0438 \u0418\u0418-\u0438\u043d\u0442\u0435\u0433\u0440\u0430\u0446\u0438\u0439.\n", "\n", "\ud83d\udccc \u0421\u0435\u043a\u0446\u0438\u0438:\n", "1. \u041a\u043e\u043d\u0446\u0435\u043f\u0446\u0438\u044f \u041d\u041e\u0412\u0415\u042f\n", "2. \u041f\u0440\u043e\u0435\u043a\u0442\u044b \u0438 \u0441\u0446\u0435\u043d\u0430\u0440\u0438\u0438 \u043f\u0440\u0438\u043c\u0435\u043d\u0435\u043d\u0438\u044f\n", "3. \u0413\u0440\u0430\u043d\u0442\u043e\u0432\u0430\u044f \u0430\u0440\u0445\u0438\u0442\u0435\u043a\u0442\u0443\u0440\u0430\n", "4. \u042d\u043a\u0441\u043f\u043e\u0440\u0442 \u043d\u0430 GitHub\n", "5. \u0414\u043e\u043f\u043e\u043b\u043d\u0435\u043d\u0438\u044f \u0438 \u0441\u0432\u044f\u0437\u044c \u0441 Google Drive"]}, {"cell_type": "code", "metadata": {}, "execution_count": null, "outputs": [], "source": ["# \ud83d\udcc2 \u0418\u043c\u043f\u043e\u0440\u0442 \u0431\u0438\u0431\u043b\u0438\u043e\u0442\u0435\u043a\n", "import pandas as pd\n", "from google.colab import drive\n", "drive.mount('/content/drive')\n", "print('\u2705 Google Drive \u043f\u043e\u0434\u043a\u043b\u044e\u0447\u0451\u043d')"]}, {"cell_type": "code", "metadata": {}, "execution_count": null, "outputs": [], "source": ["# \ud83d\udcc4 \u0417\u0430\u0433\u0440\u0443\u0437\u043a\u0430 \u0438 \u043e\u0442\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u0435 \u0444\u0430\u0439\u043b\u043e\u0432 \u043a\u043e\u043d\u0446\u0435\u043f\u0446\u0438\u0438 \u0438 \u043f\u0440\u043e\u0435\u043a\u0442\u043e\u0432\n", "import docx\n", "\n", "def read_docx(file_path):\n", "    doc = docx.Document(file_path)\n", "    return '\\n'.join([p.text for p in doc.paragraphs if p.text.strip()])\n", "\n", "concept_path = '/content/drive/MyDrive/NOVEYA/\u0410\u043d\u043d\u043e\u0442\u0430\u0446\u0438\u044f \u0415\u0434\u0438\u043d\u043e\u0439 \u041c\u0435\u0442\u043e\u0434\u043e\u043b\u043e\u0433\u0438\u0438 \u041d\u041e\u0412\u0415\u042f.docx'\n", "projects_path = '/content/drive/MyDrive/NOVEYA/\u041f\u0420\u041e\u0415\u041a\u0422\u042b \u041d\u041e\u0412\u0415\u042f.docx'\n", "\n", "concept_text = read_docx(concept_path)\n", "projects_text = read_docx(projects_path)\n", "\n", "print('--- \u041a\u043e\u043d\u0446\u0435\u043f\u0446\u0438\u044f \u041d\u041e\u0412\u0415\u042f ---')\n", "print(concept_text[:2000])\n", "print('\\n--- \u041f\u0440\u043e\u0435\u043a\u0442\u044b \u041d\u041e\u0412\u0415\u042f ---')\n", "print(projects_text[:2000])"]}, {"cell_type": "code", "metadata": {}, "execution_count": null, "outputs": [], "source": ["# \ud83d\udd04 \u042d\u043a\u0441\u043f\u043e\u0440\u0442 \u0432 GitHub\n", "from google.colab import auth\n", "auth.authenticate_user()\n", "\n", "!git config --global user.name 'YourName'\n", "!git config --global user.email 'youremail@example.com'\n", "\n", "# \u041f\u0440\u0438\u043c\u0435\u0440 \u0437\u0430\u0433\u0440\u0443\u0437\u043a\u0438 (\u0437\u0430\u043c\u0435\u043d\u0438\u0442\u0435 URL \u043d\u0430 \u0441\u0432\u043e\u0439 \u0440\u0435\u043f\u043e\u0437\u0438\u0442\u043e\u0440\u0438\u0439)\n", "!git clone https://github.com/username/NOVEYA.git\n", "%cd NOVEYA\n", "\n", "# \u041a\u043e\u043f\u0438\u0440\u0443\u0435\u043c \u0444\u0430\u0439\u043b\u044b \u0432 \u0440\u0435\u043f\u043e\u0437\u0438\u0442\u043e\u0440\u0438\u0439\n", "!cp '/content/drive/MyDrive/NOVEYA/\u0410\u043d\u043d\u043e\u0442\u0430\u0446\u0438\u044f \u0415\u0434\u0438\u043d\u043e\u0439 \u041c\u0435\u0442\u043e\u0434\u043e\u043b\u043e\u0433\u0438\u0438 \u041d\u041e\u0412\u0415\u042f.docx' .\n", "!cp '/content/drive/MyDrive/NOVEYA/\u041f\u0420\u041e\u0415\u041a\u0422\u042b \u041d\u041e\u0412\u0415\u042f.docx' .\n", "\n", "!git add .\n", "!git commit -m '\u041e\u0431\u043d\u043e\u0432\u043b\u0435\u043d\u0438\u0435 \u043a\u043e\u043d\u0446\u0435\u043f\u0446\u0438\u0438 \u0438 \u043f\u0440\u043e\u0435\u043a\u0442\u043e\u0432 \u041d\u041e\u0412\u0415\u042f'\n", "!git push origin main"]}], "metadata": {"kernelspec": {"display_name": "Python 3", "language": "python", "name": "python3"}, "language_info": {"name": "python", "version": "3.x"}}, "nbformat": 4, "nbformat_minor": 2}
