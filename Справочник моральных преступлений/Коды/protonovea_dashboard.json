
{
  "dashboard": {
    "id": null,
    "uid": null,
    "title": "Protonovea Node Monitor",
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 0,
    "refresh": "10s",
    "panels": [
      {
        "type": "graph",
        "title": "CPU Usage",
        "targets": [
          {
            "expr": "rate(node_cpu_seconds_total{mode='user'}[1m])",
            "refId": "A"
          }
        ],
        "id": 1
      },
      {
        "type": "graph",
        "title": "Memory Usage",
        "targets": [
          {
            "expr": "node_memory_Active_bytes / node_memory_MemTotal_bytes",
            "refId": "B"
          }
        ],
        "id": 2
      }
    ]
  },
  "overwrite": true
}
